@page
@model SpaVuiVe_FE.Pages.SkinCareRoutines.IndexModel
@{
    ViewData["Title"] = "Skincare Routine Management";
}

<style>
    .routine-step {
        text-align: center;
        width: 250px;
        margin: 0 15px;
    }

    .steps-container {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        position: relative;
        margin-bottom: 40px;
    }

    .step-number {
        width: 35px;
        height: 35px;
        background-color: var(--bs-primary);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        margin: 0 auto 20px;
        position: relative;
        z-index: 2;
    }

    .step-line {
        position: absolute;
        height: 2px;
        background-color: #dee2e6;
        top: 17px;
        left: 50%;
        right: 50%;
        z-index: 1;
    }

    .routine-card {
        transition: transform 0.2s;
        cursor: pointer;
    }

    .routine-card:hover {
        transform: translateY(-5px);
    }

    .product-card {
        transition: transform 0.2s;
    }

    .product-card:hover {
        transform: translateY(-5px);
    }

    .modal-dialog {
        max-width: 800px;
    }

    .modal-body {
        max-height: 80vh;
        overflow-y: auto;
    }

    .step-info-card {
        margin-top: 20px;
        text-align: left;
    }
</style>

<div class="container py-4">
    <!-- Routine Cards List -->
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Oily Skin Routine -->
            <div class="card mb-4 routine-card" onclick="showRoutineDetails('oily', this)" data-bs-toggle="modal" data-bs-target="#routineModal">
                <div class="card-body d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-primary text-white p-3 rounded-circle">
                            <i class="bi bi-droplet-fill"></i>
                        </div>
                    </div>
                    <div class="ms-4">
                        <h5 class="card-title mb-1">Oily Skin Routine</h5>
                        <p class="card-text text-muted mb-0">Perfect for controlling excess oil and preventing breakouts</p>
                    </div>
                    <div class="ms-auto">
                        <i class="bi bi-chevron-right"></i>
                    </div>
                </div>
            </div>

            <!-- Dry Skin Routine -->
            <div class="card mb-4 routine-card" onclick="showRoutineDetails('dry', this)" data-bs-toggle="modal" data-bs-target="#routineModal">
                <div class="card-body d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-primary text-white p-3 rounded-circle">
                            <i class="bi bi-moisture"></i>
                        </div>
                    </div>
                    <div class="ms-4">
                        <h5 class="card-title mb-1">Dry Skin Routine</h5>
                        <p class="card-text text-muted mb-0">Focused on hydration and maintaining skin barrier</p>
                    </div>
                    <div class="ms-auto">
                        <i class="bi bi-chevron-right"></i>
                    </div>
                </div>
            </div>

            <!-- Combination Skin Routine -->
            <div class="card mb-4 routine-card" onclick="showRoutineDetails('combination', this)" data-bs-toggle="modal" data-bs-target="#routineModal">
                <div class="card-body d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-primary text-white p-3 rounded-circle">
                            <i class="bi bi-circle-half"></i>
                        </div>
                    </div>
                    <div class="ms-4">
                        <h5 class="card-title mb-1">Combination Skin Routine</h5>
                        <p class="card-text text-muted mb-0">Balanced care for different facial zones</p>
                    </div>
                    <div class="ms-auto">
                        <i class="bi bi-chevron-right"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Routine Details Modal -->
<div class="modal fade" id="routineModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title" id="routineTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Steps Section -->
                <div class="mb-5">
                    <h5 class="text-primary mb-4">Daily Steps</h5>
                    <div id="routineSteps" class="steps-container"></div>
                </div>

                <!-- Recommended Products -->
                <div class="recommended-products">
                    <h5 class="text-primary mb-4">Recommended Products</h5>
                    <div class="row row-cols-1 row-cols-md-2 g-4" id="recommendedProducts"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const routineData = {
            oily: {
                title: "Oily Skin Routine",
                steps: [
                    { step: 1, product: "Oil Control Cleanser", duration: "1-2 minutes", notes: "Use lukewarm water and gentle circular motions" },
                    { step: 2, product: "Alcohol-free Toner", duration: "30 seconds", notes: "Pat gently with clean hands or cotton pad" },
                    { step: 3, product: "Light Moisturizer", duration: "1 minute", notes: "Focus on T-zone and use light, upward strokes" }
                ],
                products: [
                    {
                        name: "Oil Control Foam Cleanser",
                        price: "$22.99",
                        description: "Deeply cleanses without over-drying, perfect for oily skin types",
                        image: "/api/placeholder/300/200"
                    },
                    {
                        name: "Mattifying Moisturizer",
                        price: "$28.99",
                        description: "Light, oil-free hydration with shine control",
                        image: "/api/placeholder/300/200"
                    }
                ]
            },
            dry: {
                title: "Dry Skin Routine",
                steps: [
                    { step: 1, product: "Cream Cleanser", duration: "1-2 minutes", notes: "Gentle massage with warm (not hot) water" },
                    { step: 2, product: "Hydrating Toner", duration: "30 seconds", notes: "Pat into skin while face is still damp" },
                    { step: 3, product: "Rich Moisturizer", duration: "1-2 minutes", notes: "Apply generously using pressing motions" }
                ],
                products: [
                    {
                        name: "Creamy Hydrating Cleanser",
                        price: "$24.99",
                        description: "Nourishing cream cleanser that maintains skin barrier",
                        image: "/api/placeholder/300/200"
                    },
                    {
                        name: "Intensive Moisturizer",
                        price: "$32.99",
                        description: "Rich, deep hydration for dry skin types",
                        image: "/api/placeholder/300/200"
                    }
                ]
            }
            // Add more routine types as needed
        };

        function showRoutineDetails(routineType, clickedCard) {
            // Remove active class from all cards
            document.querySelectorAll('.routine-card').forEach(card => {
                card.classList.remove('active-routine');
            });

            // Add active class to clicked card
            clickedCard.classList.add('active-routine');

            const routine = routineData[routineType];
            if (!routine) return;

            // Update modal title
            document.getElementById('routineTitle').textContent = routine.title;

            // Populate steps
            const stepsContainer = document.getElementById('routineSteps');
            stepsContainer.innerHTML = '';

            // Add connecting lines between steps
            const totalSteps = routine.steps.length;
            for (let i = 0; i < totalSteps - 1; i++) {
                const line = document.createElement('div');
                line.className = 'step-line';
                stepsContainer.appendChild(line);
            }

            // Add steps
            routine.steps.forEach((step, index) => {
                const stepElement = document.createElement('div');
                stepElement.className = 'routine-step';
                stepElement.innerHTML = `
                    <div class="step-number">${step.step}</div>
                    <div class="step-info-card card shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title text-primary">${step.product}</h6>
                            <p class="card-text mb-1"><small class="text-muted">Duration: ${step.duration}</small></p>
                            <p class="card-text mb-0">${step.notes}</p>
                        </div>
                    </div>
                `;
                stepsContainer.appendChild(stepElement);
            });

            // Populate products
            const productsContainer = document.getElementById('recommendedProducts');
            productsContainer.innerHTML = routine.products.map(product => `
                <div class="col">
                    <div class="card h-100 product-card">
                        <img src="${product.image}" class="card-img-top" alt="${product.name}">
                        <div class="card-body">
                            <h6 class="card-title">${product.name}</h6>
                            <p class="card-text">${product.description}</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-primary fw-bold">${product.price}</span>
                                <button class="btn btn-outline-primary btn-sm">Add to Cart</button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }
    </script>
}
