@page
@model SkincareProductSalesSystem.RazorWebApp.Pages.SkinTestPages.IndexModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid services py-5">
    <div class="container py-5">
        <div class="mx-auto text-center mb-5" style="max-width: 800px;">
            <p class="fs-4 text-uppercase text-center" style="color: #ffc0cb;">Spa Vui Ve</p>
            <h1 class="display-3">Chăm sóc sắc đẹp, chăm sóc tâm hồn</h1>
        </div>
        @{
            if (Model.SkinTest.Count <= 0)
            {
                <div class="text-center">
                    <h2>Hiện tại chưa có bài kiểm tra nào</h2>
                </div>
            }
            for (int i = 0; i < Model.SkinTest.Count; i++)
            {
                <div class="row g-4">

                    <div class="col-lg-12 py-2">
                        <div class="services-item bg-light border-4 border-end rounded p-4" style="border: 2px solid #ffc0cb;color: #ffc0cb;">
                            <div class="row align-items-center">
                                <div class="col-8">
                                    <div class="services-content text-end">
                                        <h3>Câu hỏi @(i + 1)</h3>
                                        <p>@Model.SkinTest[i].Question</p>
                                        @foreach (var option in Model.SkinTest[i].SkinTestOptions)
                                        {
                                            <a href="#"
                                               class="btn rounded-pill py-2 px-4 mx-2 my-2 option-btn"
                                               data-question="@Model.SkinTest[i].QuestionId"
                                               data-option="@option.OptionId"
                                               data-skinTypeId="@option.SkinTypeId"
                                               style="background-color: #ffc0cb; color: #333; border: 2px solid #ffc0cb; transition: all 0.3s ease;">
                                                @option.OptionText
                                            </a>
                                        }

                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="services-img d-flex align-items-center justify-content-center rounded">
                                        <img src="~/images/question_1.jpg" class="img-fluid rounded" alt="">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>


                </div>
            }

            if (Model.SkinTest.Count > 0)
            {
                <div class="col-12 my-2">
                    <div class="services-btn text-center">
                        <form method="post">
                            <button type="submit" class="btn custom-btn rounded-pill py-3 px-5 me-3">Xem kết quả</button>

                        </form>

                       
                    </div>
                </div>
            }
        }
    </div>
</div>
<style>
    .custom-btn {
        background-color: #ffc0cb;
        color: #333;
        border: 2px solid #ffc0cb;
        transition: all 0.3s ease;
    }

        .custom-btn:hover {
            background-color: transparent;
            color: #333;
            border-color: #ffc0cb;
        }
</style>
<script>
         document.querySelectorAll(".option-btn").forEach(button => {
        button.addEventListener("click", function (event) {
            event.preventDefault();

            let optionId = this.getAttribute("data-option");
            let questionId = this.getAttribute("data-question");
            let skinTypeId = this.getAttribute("data-skinTypeId");

            console.log(optionId)
            let optionText = this.innerText;

            let requestData = {
                questionId: questionId,
                option: {
                    optionId: optionId,
                    optionText: optionText,
                    skinTypeId: skinTypeId
                }
            };

            fetch(window.location.pathname + "?handler=SaveAnswer", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(requestData)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Remove old chosen option highlight
                    document.querySelectorAll(`.option-btn[data-question="${questionId}"]`)
                        .forEach(btn => btn.style.backgroundColor = "#ffc0cb");

                    // Highlight chosen one
                    this.style.backgroundColor = "#ff69b4";
                }
            })
            .catch(error => console.error('Error:', error));
        });
    });

</script>



