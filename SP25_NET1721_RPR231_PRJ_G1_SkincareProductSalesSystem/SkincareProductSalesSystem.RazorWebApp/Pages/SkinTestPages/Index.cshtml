@page
@model SkincareProductSalesSystem.RazorWebApp.Pages.SkinTestPages.IndexModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Pages/Shared/_Layout.cshtml";
    // var demo = Model.SkinTest.Count();
}

<div class="container-fluid services py-5">
    <div class="container py-5">
        <div class="mx-auto text-center mb-5" style="max-width: 800px;">
            <p class="fs-4 text-uppercase text-center" style="color: #ffc0cb;">Spa Vui Ve</p>
            <h1 class="display-3">Chăm sóc sắc đẹp, chăm sóc tâm hồn</h1>
        </div>
        @{
            if (Model.SkinTest.Count <= 0)
            {
                <div class="text-center">
                    <h2>Hiện tại chưa có bài kiểm tra nào</h2>
                </div>
            }
            for (int i = 0; i < Model.SkinTest.Count; i++)
            {
                <div class="row g-4">

                    <div class="col-lg-12">
                        <div class="services-item bg-light border-4 border-end rounded p-4" style="border: 2px solid #ffc0cb;color: #ffc0cb;">
                            <div class="row align-items-center">
                                <div class="col-8">
                                    <div class="services-content text-end">
                                        <h3>Câu hỏi @i</h3>
                                        <p>@Model.SkinTest[i]</p>
                                        <div class="row mb-3">
                                            <div class="col-6 d-flex flex-column justify-content-between">
                                                <a href="#" class="btn rounded-pill py-2 px-4 mx-2  my-2" style="background-color: #ffc0cb; color: #333; border: 2px solid #ffc0cb; transition: all 0.3s ease;">A. @Model.SkinTest[i].OptionA</a>
                                                <a href="#" class="btn rounded-pill py-2 px-4 mx-2  my-2" style="background-color: #ffc0cb; color: #333; border: 2px solid #ffc0cb; transition: all 0.3s ease;">B. @Model.SkinTest[i].OptionB</a>
                                            </div>
                                            <div class="col-6 d-flex flex-column justify-content-between">
                                                <a href="#" class="btn rounded-pill py-2 px-4 mx-2  my-2" style="background-color: #ffc0cb; color: #333; border: 2px solid #ffc0cb; transition: all 0.3s ease;">C. @Model.SkinTest[i].OptionC</a>
                                                <a href="#" class="btn rounded-pill py-2 px-4 mx-2  my-2" style="background-color: #ffc0cb; color: #333; border: 2px solid #ffc0cb; transition: all 0.3s ease;">D. @Model.SkinTest[i].OptionD</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="services-img d-flex align-items-center justify-content-center rounded">
                                        <img src="~/images/question_1.jpg" class="img-fluid rounded" alt="">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 my-2">
                        <div class="services-btn text-center">
                            <a href="#" class="btn rounded-pill py-3 px-5" style="background-color: #ffc0cb; color: #333; border: 2px solid #ffc0cb; transition: all 0.3s ease;">Xem kết quả</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>



