@page
@using SkincareProductSalesSystem.RazorWebApp.Models
@model SkincareProductSalesSystem.RazorWebApp.Pages.SkinTestPages.ResultModel

@{
    ViewData["Title"] = "Result";
    Layout = "~/Pages/Shared/_Layout.cshtml";
 
}

<div class="container-fluid testimonial py-5 text-black">
    @{
        if(Model.SkinType == null){
            <div class="container py-5">
                <p class="fs-4 text-uppercase text-primary">Hoàn thành bài trắc nghiệm</p>
                <h2>Không có kết quả</h2>
            </div>
        }else {
            <div class="container py-5">
                <div class="text-center mx-auto mb-5" style="max-width: 800px;">
                    <p class="fs-4 text-uppercase text-primary">Hoàn thành bài trắc nghiệm</p>
                    <h1 class="display-4 mb-4">Kết quả loại da của bạn là @Model.SkinType.Name</h1>
                </div>
                <div class="owl-carousel testimonial-carousel">
                    <div class="rounded p-4 my-2" style="background: #ffc0cb" ;>
                        <div class="row">
                            <div class="col-3">
                                <div class="d-flex align-items-center flex-column mx-auto">
                                    <div class="rounded-circle mb-4" style="border: dashed; border-color: var(--bs-white); width: 200px; height: 200px; overflow: hidden; display: flex; justify-content: center; align-items: center;">
                                        <img src="~/images/normal_skin.jpg" class="img-fluid rounded-circle" alt="" style="object-fit: cover; width: 100%; height: 100%;">
                                    </div>
                                    <div class="text-center">
                                        <h4 class="mb-2" style="color: #ff4f9d;">@Model.SkinType.Name</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="col-9">
                                <div class="position-absolute" style="top: 20px; right: 25px;">
                                    <i class="fa fa-quote-right fa-2x text-secondary"></i>
                                </div>
                                <div class="testimonial-content">
                                    <div class="d-flex mb-4">
                                        <i class="fas fa-star text-primary"></i>
                                        <i class="fas fa-star text-primary"></i>
                                        <i class="fas fa-star text-primary"></i>
                                        <i class="fas fa-star text-primary"></i>
                                        <i class="fas fa-star"></i>
                                    </div>
                                    <p class="fs-5 mb-0">
                                        @(Model.SkinType.Description)
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
  
    
</div>