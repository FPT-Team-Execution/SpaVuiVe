@page
@model SkincareProductSalesSystem.RazorWebApp.Pages.SkinTypePages.IndexModel
@{
    ViewData["Title"] = "Da mặt";
    var notUpdated = "Chưa cập nhật";
}

<div class="testimonial">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <div class="titlepage">
                    <h2>Các Loại Da</h2>
                    <p>
                        Hiểu rõ về loại da của bạn là bước đầu tiên để có một làn da khỏe mạnh.
                        Khám phá đặc điểm và cách chăm sóc phù hợp với từng loại da.
                    </p>
                </div>
            </div>
        </div>
        <section id="demos">
            <div class="row">
                <div class="col-md-12">
                    <div class="owl-carousel owl-theme">
                        @foreach (var skinType in @Model.SkinTypes)
                        {
                            <div class="item my-2">
                                <span class="skin-icon bg-primary text-white">
                                    @(string.IsNullOrEmpty(skinType.Name) ? "?" : skinType.Name.Substring(0, 1))
                                </span>
                                <h3 style="color: #ffc0cb;">@(string.IsNullOrEmpty(skinType.Name) ? notUpdated : skinType.Name)</h3>
                                <div class="skin-content">
                                    <div class="description-section">
                                        <h4>Mô tả</h4>
                                        <p class="description">@(string.IsNullOrEmpty(skinType.Description) ? notUpdated : skinType.Description)</p>
                                    </div>

                                    <div class="characteristics">
                                        <h4>Đặc điểm nhận dạng</h4>
                                        <p>@(string.IsNullOrEmpty(skinType.Characteristics) ? notUpdated : skinType.Characteristics)</p>
                                    </div>

                                    <div class="ingredients">
                                        <div class="recommended">
                                            <h4>
                                                <i class="recommended-icon">✓</i>
                                                Thành phần nên dùng
                                            </h4>
                                            <p>@(string.IsNullOrEmpty(skinType.RecommendedIngredients) ? notUpdated : skinType.RecommendedIngredients)</p>
                                        </div>
                                        <div class="avoid">
                                            <h4>
                                                <i class="avoid-icon">✕</i>
                                                Thành phần cần tránh
                                            </h4>
                                            <p>@(string.IsNullOrEmpty(skinType.AvoidIngredients) ? notUpdated : skinType.AvoidIngredients)</p>
                                        </div>
                                    </div>

                                    <div class="care-instructions">
                                        <h4>
                                            <i class="care-icon">❖</i>
                                            Hướng dẫn chăm sóc
                                        </h4>
                                        <p>@(string.IsNullOrEmpty(skinType.CareInstructions) ? notUpdated : skinType.CareInstructions)</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

<style>

    .testimonial {
        padding: 60px 0;
        background: var(--light-bg);
    }

        .testimonial .titlepage h2 {
            margin-bottom: 20px;
        }

        .testimonial .titlepage p {
            color: var(--dark-text);
            font-size: 17px;
            line-height: 1.8;
            max-width: 800px;
            margin: 0 auto;
        }

    .item {
        text-align: left;
        background: #ffffff;
        border-radius: 20px;
        padding: 30px;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        margin: 15px;
    }

        .item:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }

    .skin-icon {
        background: var(--primary-color);
        width: 60px;
        height: 60px;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 15px;
        text-transform: uppercase;
    }

    .item h3 {
        font-size: 28px;
        color: var(--dark-text);
        margin-bottom: 20px;
        border-bottom: 2px solid var(--primary-color);
        padding-bottom: 10px;
        font-weight: 600;
    }

    .item h4 {
        font-size: 18px;
        color: var(--primary-color);
        margin: 15px 0 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .skin-content p {
        color: var(--gray-text);
        font-size: 16px;
        line-height: 1.6;
        margin-bottom: 15px;
    }

    .description-section,
    .characteristics,
    .ingredients,
    .care-instructions {
        background: var(--light-bg);
        padding: 0px;
        border-radius: 10px;
        margin: 15px 0;
        border-left: 4px solid var(--primary-color);
    }

    .recommended, .avoid {
        margin: 15px 0;
        padding: 15px;
        border-radius: 8px;
        background: #fff;
    }

    .avoid {
        border-left: 4px solid var(--danger-color);
    }

        .avoid h4 {
            color: var(--danger-color);
        }

    .recommended-icon,
    .avoid-icon,
    .care-icon {
        font-size: 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
    }

    .recommended-icon {
        color: #28a745;
    }

    .avoid-icon {
        color: var(--danger-color);
    }

    .care-icon {
        color: var(--primary-color);
    }

    .owl-dot {
        background: var(--primary-color) !important;
        width: 12px;
        height: 12px;
        border-radius: 6px;
        margin: 0 5px;
        transition: all 0.3s ease;
        opacity: 0.5;
    }

        .owl-dot.active {
            width: 25px;
            opacity: 1;
        }

    .titlepage {
        text-align: center;
        padding-bottom: 40px;
    }

        .titlepage h2 {
            font-size: 42px;
            color: var(--dark-text);
            margin-bottom: 15px;
            font-weight: bold;
        }
    .titlepage h2 {
        font-size: 32px;
    }

    .item h3 {
        font-size: 24px;
    }

    .skin-content p {
        font-size: 15px;
    }

    
</style>