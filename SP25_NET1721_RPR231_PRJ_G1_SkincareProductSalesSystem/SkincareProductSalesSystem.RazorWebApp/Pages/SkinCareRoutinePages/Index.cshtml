@page
@model IndexModel
@{
    ViewData["Title"] = "Skincare Routine Management";
}

<style>
    .routine-step {
        text-align: center;
        width: 250px;
        margin: 0 15px;
    }

    .steps-container {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        position: relative;
        margin-bottom: 40px;
    }

    .step-number {
        width: 35px;
        height: 35px;
        background-color: var(--bs-primary);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        margin: 0 auto 20px;
        position: relative;
        z-index: 2;
    }

    .step-line {
        position: absolute;
        height: 2px;
        background-color: #dee2e6;
        top: 17px;
        left: 50%;
        right: 50%;
        z-index: 1;
    }

    .routine-card {
        transition: transform 0.2s;
        cursor: pointer;
    }

        .routine-card:hover {
            transform: translateY(-5px);
        }
</style>
<section style="background-image: url('images/banner-1.jpg');background-repeat: no-repeat;background-size: cover;">
    <div class="container-lg">
        <div class="row">
            <div class="col-lg-6 pt-5 mt-5">
                <h2 class="display-1 ls-1">
                    <span class="fw-bold text-pink">Natural</span> Skincare at your
                    <span class="fw-bold">
                        Doorsteps
                    </span>
                </h2>
                <div class="d-flex gap-3">
                    <a href="#" class="btn btn-primary bg-pink text-uppercase fs-6 rounded-pill px-4 py-3 mt-3">
                        Start
                        Shopping
                    </a>
                    <a href="#" class="btn btn-dark text-uppercase fs-6 rounded-pill px-4 py-3 mt-3">Join Now</a>
                </div>
                <div class="row my-5">
                    <div class="col">
                        <div class="row text-dark">
                            <div class="col-auto">
                                <p class="fs-1 fw-bold lh-sm mb-0">14k+</p>
                            </div>
                            <div class="col">
                                <p class="text-uppercase lh-sm mb-0">Product Varieties</p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="row text-dark">
                            <div class="col-auto">
                                <p class="fs-1 fw-bold lh-sm mb-0">50k+</p>
                            </div>
                            <div class="col">
                                <p class="text-uppercase lh-sm mb-0">Happy Customers</p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="row text-dark">
                            <div class="col-auto">
                                <p class="fs-1 fw-bold lh-sm mb-0">10+</p>
                            </div>
                            <div class="col">
                                <p class="text-uppercase lh-sm mb-0">Store Locations</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-sm-3 row-cols-lg-3 g-0 justify-content-center">
            <div class="col">
                <div class="card border-0 bg-pink rounded-0 p-4 text-light">
                    <div class="row">
                        <div class="col-md-3 text-center">
                            <svg width="60" height="60">
                                <use xlink:href="#fresh"></use>
                            </svg>
                        </div>
                        <div class="col-md-9">
                            <div class="card-body p-0">
                                <h5 class="text-light">Glow from Within</h5>
                                <p class="card-text">Nourish your skin for a healthy, radiant, and natural glow.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 bg-secondary rounded-0 p-4 text-light">
                    <div class="row">
                        <div class="col-md-3 text-center">
                            <svg width="60" height="60">
                                <use xlink:href="#organic"></use>
                            </svg>
                        </div>
                        <div class="col-md-9">
                            <div class="card-body p-0">
                                <h5 class="text-light">100% Natural Ingredients</h5>
                                <p class="card-text">Made from pure, natural extracts, safe for all skin types.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 bg-danger rounded-0 p-4 text-light">
                    <div class="row">
                        <div class="col-md-3 text-center">
                            <svg width="60" height="60">
                                <use xlink:href="#delivery"></use>
                            </svg>
                        </div>
                        <div class="col-md-9">
                            <div class="card-body p-0">
                                <h5 class="text-light">Free Shipping Nationwide</h5>
                                <p class="card-text">
                                    Enjoy fast, reliable, and free shipping across the country.

                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<div class="container py-4">
    <div class="row justify-content-center g-4">
        @foreach (var routine in Model.SkinCareRoutines)
        {
            <div class="col-md-4 col-sm-6">
                <div class="card routine-card h-100" onclick="showRoutineDetails('@routine.RoutineId')" data-bs-toggle="modal" data-bs-target="#routineModal">
                    <div class="card-body d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-primary text-white p-3 rounded-circle">
                                <i class="bi bi-droplet-fill"></i>
                            </div>
                        </div>
                        <div class="ms-4">
                            <h5 class="card-title mb-1">@routine.Name</h5>
                            <p class="card-text text-muted mb-0">@routine.Description</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Routine Modal</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <!-- Routine Details Modal -->
    <div class="modal fade" id="routineModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content border-0 shadow overflow-hidden">
                <!-- Modal Header -->
                <div class="modal-header border-0 bg-primary text-white">
                    <h5 class="modal-title fw-bold" id="routineTitle">
                        <i class="fas fa-calendar-check me-2"></i>Routine Details
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <!-- Modal Body -->
                <div class="modal-body p-4">
                    <!-- Daily Steps Section -->
                    <div class="section-header mb-4">
                        <h5 class="fw-bold">
                            <i class="fas fa-list-check me-2"></i>Daily Steps
                        </h5>
                    </div>

                    <!-- Timeline Steps Container -->
                    <div class="timeline-section mb-5">
                        <!-- Steps Container -->
                        <div id="routineSteps" class="steps-container">
                            <!-- Steps will be dynamically added here from your backend data -->
                        </div>

                        <!-- Navigation Controls -->
                       @*  <div class="steps-navigation">
                            <button class="prev-btn nav-btn">
                                <i class="fas fa-chevron-left"></i>
                            </button>
                            <button class="next-btn nav-btn">
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </div> *@
                    </div>

                    <!-- Recommended Products Section -->
                    <div class="section-header mb-4 mt-5">
                        <h5 class="fw-bold">
                            <i class="fas fa-shopping-bag me-2"></i>Recommended Products
                        </h5>
                    </div>

                    <div id="recommendedProducts" class="row g-4">
                        <!-- Products will be dynamically added here from your backend data -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        :root {
            --primary: #4361ee;
            --primary-light: #4895ef;
            --border-radius: 12px;
            --card-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
            --hover-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
        }

        /* Căn giữa Modal */
        .modal-dialog {
            max-width: 100%;
        }

        /* Timeline Section */
        .timeline-section {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
            overflow: hidden;
            position: relative;
        }

        /* Steps Container */
        .steps-container {
            display: flex;
            max-width: 100%;
            overflow-x: auto;
            padding: 20px;
            scroll-behavior: smooth;
            scrollbar-width: thin;
            scrollbar-color: var(--primary) #f1f1f1;
            position: relative;
            justify-content: center;
        }

            /* Hiển thị thanh cuộn khi hover */
            .steps-container:hover {
                scrollbar-width: auto;
            }

            .steps-container::-webkit-scrollbar {
                height: 6px;
            }

            .steps-container::-webkit-scrollbar-thumb {
                background: var(--primary);
                border-radius: 10px;
            }

            .steps-container::-webkit-scrollbar-track {
                background: #f1f1f1;
            }

            /* Timeline Line */
            .steps-container::before {
                content: '';
                position: absolute;
                top: 50%;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, var(--primary), var(--primary-light));
                opacity: 0.3;
                z-index: 1;
            }

        /* Step Card */
        .routine-step {
            background-color: white;
            border-radius: var(--border-radius);
            padding: 1.5rem;
            min-width: 250px;
            box-shadow: var(--card-shadow);
            position: relative;
            z-index: 2;
            border-top: 4px solid var(--primary);
            transition: var(--transition);
            text-align: center;
        }

            .routine-step:hover {
                transform: translateY(-5px);
                box-shadow: var(--hover-shadow);
            }

            /* Step Number Circle */
            .routine-step::before {
                content: attr(data-step);
                position: absolute;
                top: -20px;
                left: 50%;
                transform: translateX(-50%);
                width: 40px;
                height: 40px;
                background: var(--primary);
                color: white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: bold;
                box-shadow: 0 4px 10px rgba(67, 97, 238, 0.3);
            }

        /* Step Content */
        .step-header {
            font-weight: 600;
            font-size: 1.1rem;
            color: var(--primary);
            margin-bottom: 10px;
        }

        .step-content {
            color: #212529;
            font-size: 0.95rem;
        }

        /* Navigation Controls */
        .steps-navigation {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 15px;
        }

        .nav-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: white;
            border: 2px solid var(--primary);
            color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
        }

            .nav-btn:hover {
                background-color: var(--primary);
                color: white;
            }



       
    </style>

    <!-- Required JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const container = document.getElementById('routineSteps');

            document.querySelector('.prev-btn').addEventListener('click', function () {
                container.scrollBy({ left: -260, behavior: 'smooth' });
            });

            document.querySelector('.next-btn').addEventListener('click', function () {
                container.scrollBy({ left: 260, behavior: 'smooth' });
            });
        });

    </script>
</body>
</html>


@section Scripts {
    <script>
        function showRoutineDetails(routineId) {
            fetch(`https://localhost:7000/skin-care-routines/${routineId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.status !== 200 || !data.data || data.data.length === 0) {
                        console.error("Error: Invalid response from API");
                        return;
                    }
                    console.log(data);
                    // Lấy routine đầu tiên từ danh sách data
                    const routine = data.data[0];

                    // Cập nhật tiêu đề modal
                    document.getElementById('routineTitle').textContent = routine.name;

                    // Cập nhật danh sách các bước routine
                    const stepsContainer = document.getElementById('routineSteps');
                    stepsContainer.innerHTML = '';

                    routine.routineProducts
                        .sort((a, b) => a.stepOrder - b.stepOrder) // Sắp xếp theo thứ tự bước
                        .forEach((step, index) => {
                            stepsContainer.innerHTML += `
                                        <div class="routine-step">
                                            <div class="step-number">${index + 1}</div>
                                            <div class="card shadow-sm">
                                                <div class="card-body">
                                                    <h6 class="card-title text-primary">${step.step}</h6>
                                                    <p class="card-text mb-1"><small class="text-muted">Usage: ${step.usageInstructions || "N/A"}</small></p>
                                                    <p class="card-text mb-1"><small class="text-muted">Time of Day: ${step.timeOfDay}</small></p>
                                                    <p class="card-text mb-1"><small class="text-muted">Frequency: ${step.frequency}</small></p>
                                                </div>
                                            </div>
                                        </div>`;
                        });

                    // Cập nhật danh sách sản phẩm gợi ý (nếu có)
                    const productsContainer = document.getElementById('recommendedProducts');
                    productsContainer.innerHTML = '';

                    if (routine.routineProducts.length > 0) {
                        routine.routineProducts.forEach(product => {
                            productsContainer.innerHTML += `
                                        <div class="col">
                                            <div class="card h-100 product-card">
                                                        <img src="https://i.pinimg.com/736x/c0/0d/2e/c00d2e335ecd0089275980c4d0956c8b.jpg" class="card-img-top" alt="${product.step}">
                                                <div class="card-body">
                                                    <h6 class="card-title">${product.step}</h6>
                                                    <p class="card-text">${product.usageInstructions || "No details available"}</p>
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span class="text-primary fw-bold">${product.frequency}</span>
                                                        <button class="btn btn-outline-primary btn-sm">Add to Cart</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>`;
                        });
                    } else {
                        productsContainer.innerHTML = `<p class="text-muted">No recommended products found.</p>`;
                    }
                })
                .catch(error => console.error('Error fetching routine details:', error));
        }
    </script>
}

}
