@page
@model             LoginModel
@{
	ViewData["Title"] = "Login";
}

@section Styles {
	<!-- Page-specific CSS -->
	<link rel="stylesheet" href="~/css/login.css" />
}

<div class="login-page">
	<div class="form">
		<form class="login-form" asp-page-handler="OnPost">
			<div class="header">Welcome back!</div>
			<br />

			<script src="https://accounts.google.com/gsi/client" async></script>
				<div id="g_id_onload"
					 data-client_id="YOUR_GOOGLE_CLIENT_ID"
					 data-login_uri="https://your.domain/your_login_endpoint"
					 data-auto_prompt="false">
				</div>
				<div class="g_id_signin"
					 data-type="standard"
					 data-size="large"
					 data-theme="outline"
					 data-text="sign_in_with"
					 data-shape="rectangular"
					 data-logo_alignment="left">
				</div>

			<br />
			<div class="header">OR</div>
			<br />

			<p class="input_label">Username</p>
			<input type="text" placeholder="" asp-for="LoginRequest.Username"/>
			<span id="validation-err" asp-validation-for="LoginRequest.Username"></span>

			<p class="input_label">Password</p>
			<input type="password" placeholder="" asp-for="LoginRequest.Password"/>
			<span id="validation-err" asp-validation-for="LoginRequest.Password"></span>
			@if (!string.IsNullOrEmpty(Model.ErrorMessage))
			{
				<div class="alert alert-danger">@Model.ErrorMessage</div>
			}
			<button type="submit">login</button>
			<p class="message">Not registered? <a href="../AccountPages/Register">Create an account</a></p>
			<p class="message"><a href="../AccountPages/ForgotPassword">Forgot Password?</a></p>
		</form>
	</div>
</div>

