@page
@model SkincareProductSalesSystem.RazorWebApp.Pages.OrderPages.IndexModel
@{
    Layout = "_Layout";
}
@section Styles {
    <style>
        .order-container {
            display: grid;
            grid-template-columns: 20% 20% 20% 10% 15% 15%;
            gap: 0px;
            margin-top: 20px;
            margin: 20px auto;
            max-width: 2000px;
            background: white;
            border-radius: 0px;
            padding: 20px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        .order-container-row {
            display: contents;
        }

        /* Pagination Styles */
        .pagination-container {
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 20px 0;
            gap: 10px;
        }

        .pagination-button {
            padding: 8px 16px;
            border: 1px solid #ddd;
            background-color: white;
            cursor: pointer;
            transition: all 0.3s ease;
            border-radius: 4px;
        }

            .pagination-button:hover {
                background-color: #f0f0f0;
            }

            .pagination-button.active {
                background-color: #007bff;
                color: white;
                border-color: #007bff;
            }

            .pagination-button:disabled {
                cursor: not-allowed;
                opacity: 0.5;
            }

        .pagination-info {
            margin: 0 15px;
            color: #666;
        }

        .pagination-form {
            display: contents;
        }

        /* Dropdown Styles */
        .dropdown {
            position: relative;
            display: inline-block;
        }

        .more-vert-icon {
            cursor: pointer;
            padding: 8px;
            border-radius: 50%;
        }

            .more-vert-icon:hover {
                background-color: #f0f0f0;
            }

        .dropdown-content {
            display: none;
            position: absolute;
            left: 0;
            background-color: #fff;
            min-width: 200px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            z-index: 1;
            border-radius: 4px;
        }

            .dropdown-content.show {
                display: block;
            }

            .dropdown-content button {
                width: 100%;
                padding: 12px 16px;
                text-align: left;
                border: none;
                min-width: 400px;
                background: none;
                cursor: pointer;
                font-size: 14px;
            }

                .dropdown-content button:hover {
                    background-color: #f0f0f0;
                }
    </style>
}

<div class="body">
    @if (Model.Orders != null && Model.Orders.Count > 0)
    {
        <div class="container">
            <div class="order-container">
                <div class="order-container-row">
                    <div style="display: flex; align-items: center;">
                        OrderId
                    </div>
                    <div style="display: flex; align-items: center;justify-content: center;">
                        Customer
                    </div>
                    <div style="display: flex; align-items: center;justify-content: center;">
                        <div class="cart-item-price">Total</div>
                    </div>
                    <div style="display: flex; align-items: center;justify-content: center;">
                        Order date
                    </div>
                    <div style="display: flex; align-items: center;justify-content: center;">
                        Status
                    </div>
                    <div style="display: flex; align-items: center;justify-content: center;">
                        Actions
                    </div>
                </div>
            </div>
            @foreach (var order in Model.Orders)
            {
                <div class="order-container">
                    <div class="order-container-row">
                        <div style="display: flex; align-items: center;">@order.OrderId</div>
                        <div style="display: flex; align-items: center;justify-content: center;">
                            @order.CustomerId
                        </div>
                        <div style="display: flex; align-items: center;justify-content: center;">
                            <div class="cart-item-price">@order.TotalAmount</div>
                        </div>
                        <div style="display: flex; align-items: center;justify-content: center;">
                            @order.OrderDate
                        </div>
                        <div style="display: flex; align-items: center;justify-content: center;">
                            <span>@order.Status</span>
                        </div>
                        <div style="display: flex; align-items: center;justify-content: center;">
                            <div class="dropdown">
                                <svg class="more-vert-icon" onclick="toggleDropdown(event, this)" width="35" height="35" viewBox="0 0 24 24">
                                    <path fill="currentColor" d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" />
                                </svg>
                                <div class="dropdown-content">
                                    <form method="post" style="margin: 0;" asp-page-handler="ViewDetail">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <input style="font-size: 1em; min-width: 200px" type="submit" name="action" value="View Detail" />
                                    </form>
                                    <form method="post" style="margin: 0;" asp-page-handler="Cancel">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <input style="font-size: 1em;  min-width: 200px" type="submit" name="action" value="Cancel Order" />
                                    </form>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            }
            <div class="pagination-container">
                <form method="get" class="pagination-form">
                    <button type="submit"
                            name="CurrentPage"
                            value="@(Model.CurrentPage - 1)"
                            class="pagination-button"
                            disabled="@(Model.CurrentPage <= 1)">
                        Previous
                    </button>
                    <div class="pagination-info">
                        Page @Model.CurrentPage of @Model.TotalPages
                    </div>
                    <button type="submit"
                            name="CurrentPage"
                            value="@(Model.CurrentPage + 1)"
                            class="pagination-button"
                            disabled="@(Model.CurrentPage >= Model.TotalPages)">
                        Next
                    </button>
                </form>
            </div>
        </div>
    }
    else
    {
        <div>Empty</div>
    }
</div>

@section Scripts {
    <script>
        // Initialize pagination when the document loads
        document.addEventListener('DOMContentLoaded', function () {
            updatePagination();
            showPage(@Model.CurrentPage);
        });

        function showPage(page) {
            const orderContainers = document.querySelectorAll('.order-container');
            const startIndex = (page - 1) * itemsPerPage + 1; // +1 to skip header
            const endIndex = page * itemsPerPage + 1; // +1 to skip header

            // Hide all order containers except the header
            orderContainers.forEach((container, index) => {
                if (index === 0) {
                    // Always show the header
                    container.style.display = 'grid';
                } else {
                    // Show only items for current page
                    const shouldShow = index >= startIndex && index < endIndex;
                    container.style.display = shouldShow ? 'grid' : 'none';
                }
            });
        }

        function updatePagination() {
            const prevButton = document.querySelector('button[value="@(Model.CurrentPage - 1)"]');
            const nextButton = document.querySelector('button[value="@(Model.CurrentPage + 1)"]');

            if (prevButton) prevButton.disabled = @Model.CurrentPage <= 1;
            if (nextButton) nextButton.disabled = @Model.CurrentPage >= @Model.TotalPages;
        }

        function toggleDropdown(event, icon) {
            event.stopPropagation();

            // Close all other dropdowns first
            var dropdowns = document.getElementsByClassName("dropdown-content");
            for (var i = 0; i < dropdowns.length; i++) {
                var openDropdown = dropdowns[i];
                if (openDropdown !== icon.nextElementSibling && openDropdown.classList.contains('show')) {
                    openDropdown.classList.remove('show');
                }
            }

            // Toggle the clicked dropdown
            icon.nextElementSibling.classList.toggle("show");
        }

        // Close dropdowns when clicking outside
        window.addEventListener('click', function (event) {
            if (!event.target.matches('.more-vert-icon')) {
                var dropdowns = document.getElementsByClassName("dropdown-content");
                for (var i = 0; i < dropdowns.length; i++) {
                    var openDropdown = dropdowns[i];
                    if (openDropdown.classList.contains('show')) {
                        openDropdown.classList.remove('show');
                    }
                }
            }
        });
    </script>
}