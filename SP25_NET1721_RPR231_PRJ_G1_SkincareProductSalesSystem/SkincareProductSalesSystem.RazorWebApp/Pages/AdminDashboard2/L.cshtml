<!DOCTYPE html>
<html lang="en">
	<head>
	<style>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		.sidebar {
			width: 250px;
			height: 100vh;
			background-color: #1a1a1a;
			padding: 20px 0;
			position: fixed;
			left: 0;
			top: 0;
		}

		.nav-item {
			padding: 15px 25px;
			color: #ffffff;
			text-decoration: none;
			display: flex;
			align-items: center;
			transition: background-color 0.3s;
			font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
		}

			.nav-item:hover {
				background-color: #2d2d2d;
			}

			.nav-item.active {
				background-color: #2d2d2d;
				border-left: 4px solid #4CAF50;
			}

		.nav-icon {
			margin-right: 12px;
			width: 20px;
			height: 20px;
		}

		.logo {
			padding: 20px 25px;
			margin-bottom: 20px;
			color: white;
			font-size: 24px;
			font-weight: bold;
			font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
		}
	</style>
	</head>
	<body>
	<div>
		<nav class="sidebar">
			<div class="logo">Dashboard</div>
			<a href="#" class="nav-item active">Home</a>
			<a href="#" class="nav-item">Products</a>
			<a href="#" class="nav-item">Accounts</a>
		</nav>
	</div>
	</body>
</html>


