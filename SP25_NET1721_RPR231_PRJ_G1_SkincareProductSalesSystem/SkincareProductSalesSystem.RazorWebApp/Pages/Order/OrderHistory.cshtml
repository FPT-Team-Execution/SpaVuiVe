@page
@model SkincareProductSalesSystem.RazorWebApp.Pages.Order.OrderHistoryModel
@{
    ViewData["Title"] = "Order History";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="order-history-container">
    <div class="header-section">
        <div class="title-section">
            <h1>Order History</h1>
@*             <p class="subtitle">manage all transactions with details on status, payment, and customer.</p> *@
        </div>
@*         <button class="date-time-button">
            <i class="fas fa-calendar"></i>
            Date & Time
        </button> *@
    </div>

    <div class="table-container">
        <table class="order-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>DATE</th>
                    <th>CUSTOMER</th>
                    <th>SERVICE TYPE</th>
                    <th>ITEM NAME</th>
                    <th>QTY</th>
                    <th>STATUS</th>
                    <th>TOTAL</th>
                    <th>ACTION</th>
                </tr>
            </thead>
            <tbody>
