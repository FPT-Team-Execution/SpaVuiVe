

<style>
    .chat-icon {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background-color: #ffc0cb;
        border-radius: 50%;
        padding: 15px;
        font-size: 30px;
        color: white;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        cursor: pointer;
    }

    .chat-box {
        position: fixed;
        bottom: 70px;
        right: 20px;
        width: 300px;
        height: 400px;
        background-color: white;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        display: none;
        padding: 10px;
    }

    .chat-box-header {
        font-weight: bold;
        margin-bottom: 10px;
        background-color: #ffc0cb;
        padding: 10px;
        border-radius: 5px;
        color: white;
    }

    .chat-box-body {
        overflow-y: auto;
        height: 80%;
        //padding: 5px;
        border: 1px solid #ddd;
        border-radius: 5px;
    }

    .chat-input {
        width: 100%;
        padding: 10px;
        border-radius: 5px;
        border: 1px solid #ddd;
    }

    .icon-container {
        background-color: #ffc0cb;
        width: 50px;
        height: 50px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

</style>

<!-- Icon chat -->
<div class="chat-icon rounded-circle  icon-container" onclick="toggleChat()">
    <div class="">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-robot" viewBox="0 0 16 16">
