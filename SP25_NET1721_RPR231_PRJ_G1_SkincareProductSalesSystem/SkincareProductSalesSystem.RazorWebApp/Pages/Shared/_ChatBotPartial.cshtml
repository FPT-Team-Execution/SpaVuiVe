            <path d="M8.5 1.866a1 1 0 1 0-1 0V3h-2A4.5 4.5 0 0 0 1 7.5V8a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1v1a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-1a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1v-.5A4.5 4.5 0 0 0 10.5 3h-2zM14 7.5V13a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V7.5A3.5 3.5 0 0 1 5.5 4h5A3.5 3.5 0 0 1 14 7.5" />
        </svg>
    </div>
</div>


<!-- Khung chat -->
<div class="chat-box mr-4" id="chatBox" style="right: 70px;">
    <div class="chat-box-header">Tư vấn với Spa bot</div>
    <div class="chat-box-body">
        <!-- Nội dung chat sẽ xuất hiện ở đây -->
    </div>
    <div class="chat-input-container d-flex" style="border-top: 1px solid rgba(0, 0, 0, 0.2); border-radius: 10px;">
        <input type="text" class="chat-input form-control" placeholder="Nhập tin nhắn" style="border-radius: 5px; border: 1px solid rgba(0, 0, 0, 0.2);">
        <button class="chat-send-btn ml-1" style="border: 1px solid rgba(0, 0, 0, 0.2); border-radius: 5px; background-color: white;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-send" viewBox="0 0 16 16">
                <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576zm6.787-8.201L1.591 6.602l4.339 2.76z" />
            </svg>
        </button>
    </div>
</div>

<script>
    function toggleChat() {
        var chatBox = document.getElementById("chatBox");
        if (chatBox.style.display === "none" || chatBox.style.display === "") {
            chatBox.style.display = "block";
        } else {
            chatBox.style.display = "none";
        }
    }
       
    function appendMessage(message, isBot = false) {
        const chatBody = document.querySelector('.chat-box-body');
        const messageDiv = document.createElement('div');
        messageDiv.style.margin = '10px';
        messageDiv.style.padding = '10px';
        messageDiv.style.borderRadius = '10px';
        messageDiv.style.maxWidth = '80%';
        messageDiv.style.wordWrap = 'break-word';

        if (isBot) {
            messageDiv.style.backgroundColor = '#ffc0cb';
            messageDiv.style.color = 'white';
            messageDiv.style.marginRight = 'auto';
        } else {
            messageDiv.style.backgroundColor = '#f0f0f0';
            messageDiv.style.marginLeft = 'auto';
        }

        messageDiv.textContent = message;
        chatBody.appendChild(messageDiv);
        chatBody.scrollTop = chatBody.scrollHeight;
    }

        async function sendMessage(message) {
        try {
            var prompt = encodeURIComponent(message);
            const response = await fetch(`https://localhost:7000/bot/chat?prompt=${prompt}`, {
                method: 'GET',
                headers: {
                    'Accept': 'application/json'
                }
            });

            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const result = await response.json(); // Đảm bảo lấy JSON toàn bộ
            return result.data; // Trả về toàn bộ đối tượng ServiceResult
        } catch (error) {
            console.error('Error:', error);
            return { Status: -1, Message: 'Failed to get response from bot', Data: null };
        }
    }


    // Initialize chat functionality
    document.addEventListener('DOMContentLoaded', function() {
        const chatInput = document.querySelector('.chat-input');
        const chatBody = document.querySelector('.chat-box-body');
        const sendButton = document.querySelector('.chat-send-btn');
        // Welcome message
        appendMessage('Xin chào! Tôi có thể giúp gì cho bạn?', true);

        // Handle input
        async function handleSendMessage() {
            const message = chatInput.value.trim();
            if (!message) return;

            // Clear input
            chatInput.value = '';

            // Add user message to chat
            appendMessage(message, false);

            // Show loading indicator
            const loadingDiv = document.createElement('div');
            loadingDiv.textContent = 'Đang trả lời...';
            loadingDiv.style.margin = '10px';
            loadingDiv.style.color = '#666';
            chatBody.appendChild(loadingDiv);

            try {
                // Get bot response
                const response = await sendMessage(message);
                // Remove loading indicator
                chatBody.removeChild(loadingDiv);

                if (response.error) {
                    appendMessage('Xin lỗi, có lỗi xảy ra. Vui lòng thử lại sau.', true);
                } else {
                    appendMessage(response.data || response, true);
                }
            } catch (error) {
                // Remove loading indicator
                chatBody.removeChild(loadingDiv);
                appendMessage('Xin lỗi, có lỗi xảy ra. Vui lòng thử lại sau.', true);
            }
        }

        // Handle Enter key
        chatInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                handleSendMessage();
            }
        });

        // Handle button click
        sendButton.addEventListener('click', handleSendMessage);

        // Add clear chat button
        const header = document.querySelector('.chat-box-header');
        const clearButton = document.createElement('button');
        clearButton.textContent = '↻';
        clearButton.style.float = 'right';
        clearButton.style.background = 'none';
        clearButton.style.border = 'none';
        clearButton.style.color = 'white';
        clearButton.style.cursor = 'pointer';
        clearButton.onclick = function() {
            chatBody.innerHTML = '';
            appendMessage('Xin chào! Tôi có thể giúp gì cho bạn?', true);
        };
        header.appendChild(clearButton);
    });

    // Update your existing toggleChat function
    function toggleChat() {
        var chatBox = document.getElementById("chatBox");
        if (chatBox.style.display === "none" || chatBox.style.display === "") {
            chatBox.style.display = "block";
            // Scroll to bottom when opening
            const chatBody = document.querySelector('.chat-box-body');
            chatBody.scrollTop = chatBody.scrollHeight;
        } else {
            chatBox.style.display = "none";
        }
    }
</script>