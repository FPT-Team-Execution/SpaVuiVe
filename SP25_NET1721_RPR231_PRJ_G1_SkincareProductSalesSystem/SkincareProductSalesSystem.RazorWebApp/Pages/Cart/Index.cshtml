@page
@model SkincareProductSalesSystem.RazorWebApp.Pages.Cart.IndexModel
@{
    Layout = "Shared/_Layout";
}

@if (Model?.IndextProductCartPage?.ProductCart != null && Model.IndextProductCartPage.ProductCart.Any())
{
    <div class="body" style="margin: 2rem;">
        <div class="address-container" style="margin: 1rem;">
            <div class="title">Địa chỉ nhận hàng</div>
            <div class="address">
                Nhật Minh (+84) 984072435
                <span>Số 15, Đường Lô Ồ, Phường Bình An, Thành Phố Dĩ An, Bình Dương</span>
            </div>
        </div>
        <div class="cart-container">
            <div class="cart-container-row">
                <div class="cart-container-cell" style="display: flex; align-items: center;">
                    <input type="checkbox">
                </div>
                <div style="display: flex; align-items: center;">
                    Product name
                </div>
                <div style="display: flex; align-items: center; justify-content: center;">
                    <div class="cart-item-price">Unit price</div>
                </div>
                <div style="display: flex; align-items: center; justify-content: center;">
                    Quantity
                </div>
                <div class="cart-item-total" style="display: flex; align-items: center; justify-content: center;">
                    Total
                </div>
                <div style="display: flex; align-items: center; justify-content: center;"></div>
            </div>
        </div>

        <div class="cart-product">
            <div class="cart-container">
                @foreach (var productCart in Model.IndextProductCartPage.ProductCart)
                {
                    <div class="cart-container-row">
                        <div class="cell" style="display: flex; align-items: center;">
                            <input type="checkbox">
                        </div>
                        <div style="display: flex;">
                            <div class="cell" style="max-width: 25%; justify-content: center; align-items: center; display: flex; padding-right: 10px;">
                                <img src="@productCart.ProductInCart.ImageUrl" alt="Sản phẩm" style="width: 100%; object-fit: cover;">
                            </div>
                            <div class="cell cart-item-details">
                                <p>@productCart.ProductInCart.Name</p>
                            </div>
                        </div>
                        <div style="display: flex; align-items: center; justify-content: center;">
                            <div class="cart-item-price">₫@productCart.ProductInCart.Price</div>
                        </div>

                        <div style="display: flex; align-items: center; justify-content: center;">
                            <div class="cart-item-actions">
                                <button onclick="changeValue(-1)">-</button>
                                <form method="post" asp-page-handler="AddToCart">
                                    <input type="hidden" name="productCartId" value="@productCart.ProductInCart.ProductId" />
                                    <input type="number" id="number" name="quantity" value="@productCart.Quantity">
                                </form>
                                <button onclick="changeValue(1)">+</button>
                            </div>
                        </div>
                        <input type="hidden" name="productCart" value="@productCart" />
                        <input type="hidden" name="productQuantity" value="@productCart.Quantity" />

                        <div class="cart-item-total" style="display: flex; align-items: center; justify-content: center;">
                            ₫@(productCart.Quantity * productCart.ProductInCart.Price)
                        </div>
                        <div style="display: flex; align-items: center; justify-content: center;">
                            <i class="material-icons">close</i>
                        </div>
                    </div>
                }

            </div>
        </div>
        <div class="body" >
            <div class="address-container" style="margin: 1rem;">
                <div style="display: flex; justify-content: right;">
                    <div style="display: grid; grid-template-columns: 50% 50%; width: 20%; max-width: 30%;">
                        <div style="display: flex; justify-content: left;">Order total</div>
                        <div style="display: flex; justify-content: right;" id="orderTotalValue">₫0</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="checkout-button">
            <input type="submit" value="Order">
        </div>
        <div id="checkoutPopup" class="popup" style="display: none; position: fixed; top: 100; left: 100; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); z-index: 1000;">
            <div style="position: relative; top: 50%; left: 50%; transform: translate(-50%, -50%); background-color: white; padding: 20px; border-radius: 5px; max-width: 400px;">
                <h3>Order confirmation</h3>
                <p>Is it your last decision?</p>
                <div style="margin-top: 20px; text-align: right;">
                    <button onclick="cancelCheckout()" style="margin-right: 10px; padding: 8px 16px;">Cancel</button>
                    <form id="checkoutForm" method="post" asp-page-handler="Checkout">
                        <input type="hidden" id="selectedProductsInput" name="selectedProducts" />
                        <input type="submit" value="Confirm" style="padding: 8px 16px; background-color: #4CAF50; color: white; border: none;" />
                    </form>

                </div>
            </div>
        </div>
    </div>

}
else
{
    <div class="cart-container-row">Giỏ hàng của bạn hiện tại trống.</div>
}

@section Scripts {
    <script>
        // Add this script to your page
        function handleSelectAll() {
            // Get the main checkbox
            const selectAllCheckbox = document.querySelector('.cart-container-row:first-child input[type="checkbox"]');

            // Get all product checkboxes
            const productCheckboxes = document.querySelectorAll('.cart-product input[type="checkbox"]');

            // Add click event listener to the main checkbox
            selectAllCheckbox.addEventListener('click', function () {
                // Set all product checkboxes to match the main checkbox state
                productCheckboxes.forEach(checkbox => {
                    checkbox.checked = selectAllCheckbox.checked;
                });
            });

            // Add click event listeners to product checkboxes
            productCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('click', function () {
                    // Check if all product checkboxes are checked
                    const allChecked = Array.from(productCheckboxes).every(cb => cb.checked);
                    // Update main checkbox accordingly
                    selectAllCheckbox.checked = allChecked;
                });
            });
        }

        // Call the function when the page loads
        document.addEventListener('DOMContentLoaded', handleSelectAll);
        function handleCartFunctionality() {
            const selectAllCheckbox = document.querySelector('.cart-container-row:first-child input[type="checkbox"]');
            const productCheckboxes = document.querySelectorAll('.cart-product input[type="checkbox"]');
            const checkoutButton = document.querySelector('.checkout-button input[type="submit"]');
            const popup = document.getElementById('checkoutPopup');
            const checkoutForm = document.getElementById('checkoutForm');

            // Select all functionality
            selectAllCheckbox.addEventListener('click', function () {
                productCheckboxes.forEach(checkbox => {
                    checkbox.checked = selectAllCheckbox.checked;
                });
            });

            productCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('click', function () {
                    const allChecked = Array.from(productCheckboxes).every(cb => cb.checked);
                    selectAllCheckbox.checked = allChecked;
                });
            });

            // Modify the checkout button click handler
            checkoutButton.addEventListener('click', function (e) {
                e.preventDefault();

                // Get selected products
                const selectedProducts = [];
                productCheckboxes.forEach((checkbox) => {
                    if (checkbox.checked) {
                        const productContainer = checkbox.closest('.cart-container-row');
                        const productId = productContainer.querySelector('input[name="productCartId"]').value;
                        const quantity = productContainer.querySelector('input[name="quantity"]').value;

                        selectedProducts.push({
                            productId: productId,
                            quantity: parseInt(quantity)
                        });
                    }
                });

                if (selectedProducts.length === 0) {
                    alert('Please select at least one product');
                    return;
                }

                // Store selected products data for form submission
                document.getElementById('selectedProductsInput').value = JSON.stringify(selectedProducts);

                // Show popup
                popup.style.display = 'block';
            });

            // Add form submit handler
            checkoutForm.addEventListener('submit', function (e) {
                // The form will submit automatically with the data in selectedProductsInput
                popup.style.display = 'none';
            });
        }

        function cancelCheckout() {
            document.getElementById('checkoutPopup').style.display = 'none';
        }

        function confirmCheckout() {
            document.getElementById('checkoutForm').submit();
        }

        document.addEventListener('DOMContentLoaded', function () {
            const selectAllCheckbox = document.querySelector('.cart-container-row:first-child input[type="checkbox"]'); // Checkbox tiêu đề
            const productCheckboxes = document.querySelectorAll('.cart-product input[type="checkbox"]'); // Checkbox sản phẩm
            const orderTotalElement = document.getElementById('orderTotalValue'); // Chỉ cập nhật số tiền

            function updateTotalPrice() {
                let total = 0;
                productCheckboxes.forEach(checkbox => {
                    if (checkbox.checked) {
                        const productRow = checkbox.closest('.cart-container-row');
                        const quantity = parseInt(productRow.querySelector('input[name="quantity"]').value, 10);
                        const price = parseFloat(productRow.querySelector('.cart-item-price').textContent.replace('₫', '').replace(/,/g, ''));
                        total += quantity * price;
                    }
                });

                orderTotalElement.textContent = `₫${total.toLocaleString()}`;
            }

            // Xử lý chọn/bỏ chọn tất cả sản phẩm khi nhấn vào checkbox tiêu đề
            selectAllCheckbox.addEventListener('change', function () {
                productCheckboxes.forEach(checkbox => {
                    checkbox.checked = selectAllCheckbox.checked;
                });
                updateTotalPrice();
            });

            // Khi người dùng nhấn vào checkbox của sản phẩm, cập nhật tổng giá trị
            productCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function () {
                    // Nếu tất cả các checkbox của sản phẩm đều được chọn, chọn luôn checkbox tiêu đề
                    const allChecked = Array.from(productCheckboxes).every(cb => cb.checked);
                    selectAllCheckbox.checked = allChecked;

                    updateTotalPrice();
                });
            });

            // Khi người dùng thay đổi số lượng sản phẩm, cập nhật tổng tiền
            document.querySelectorAll('input[name="quantity"]').forEach(input => {
                input.addEventListener('input', updateTotalPrice);
            });

            updateTotalPrice();
        });


    </script>
}