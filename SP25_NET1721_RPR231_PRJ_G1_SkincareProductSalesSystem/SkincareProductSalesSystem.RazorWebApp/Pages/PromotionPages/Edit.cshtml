@page
@model SkincareProductSalesSystem.RazorWebApp.Pages.PromotionPages.EditModel
@{
	ViewData["Title"] = "Edit Promotion";
}

<div class="container mt-4">
	<div class="card shadow-sm border-primary">
		<div class="card-header bg-primary text-white">
			<h2 class="card-title h5 m-0">Edit Promotion</h2>
		</div>
		<div class="card-body">
			<div class="table-responsive">
				<form method="post">
					<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
					<input type="hidden" asp-for="Promotion.PromotionId" />

					<table class="table table-bordered">
						<tbody>
							<tr>
								<th class="bg-light w-25">
									<label asp-for="Promotion.Code"></label>
								</th>
								<td>
									<input asp-for="Promotion.Code" class="form-control" />
									<span asp-validation-for="Promotion.Code" class="text-danger"></span>
								</td>
							</tr>
							<tr>
								<th class="bg-light">
									<label asp-for="Promotion.Name"></label>
								</th>
								<td>
									<input asp-for="Promotion.Name" class="form-control" />
									<span asp-validation-for="Promotion.Name" class="text-danger"></span>
								</td>
							</tr>
							<tr>
								<th class="bg-light">
									<label asp-for="Promotion.DiscountAmount"></label>
								</th>
								<td>
									<div class="input-group">
										<span class="input-group-text">$</span>
										<input asp-for="Promotion.DiscountAmount" class="form-control" type="number" step="0.01" />
									</div>
									<span asp-validation-for="Promotion.DiscountAmount" class="text-danger"></span>
								</td>
							</tr>
							<tr>
								<th class="bg-light">
									<label asp-for="Promotion.MinimumPurchase"></label>
								</th>
								<td>
									<div class="input-group">
										<span class="input-group-text">$</span>
										<input asp-for="Promotion.MinimumPurchase" class="form-control" type="number" step="0.01" />
									</div>
									<span asp-validation-for="Promotion.MinimumPurchase" class="text-danger"></span>
								</td>
							</tr>
							<tr>
								<th class="bg-light">
									<label asp-for="Promotion.StartDate"></label>
								</th>
								<td>
									<input asp-for="Promotion.StartDate" class="form-control" type="datetime-local" />
									<span asp-validation-for="Promotion.StartDate" class="text-danger"></span>
								</td>
							</tr>
							<tr>
								<th class="bg-light">
									<label asp-for="Promotion.EndDate"></label>
								</th>
								<td>
									<input asp-for="Promotion.EndDate" class="form-control" type="datetime-local" />
									<span asp-validation-for="Promotion.EndDate" class="text-danger"></span>
								</td>
							</tr>
							<tr>
								<th class="bg-light">
									<label asp-for="Promotion.UsageLimit"></label>
								</th>
								<td>
									<input asp-for="Promotion.UsageLimit" class="form-control" type="number" />
									<span asp-validation-for="Promotion.UsageLimit" class="text-danger"></span>
								</td>
							</tr>
							<tr>
								<th class="bg-light">
									<label asp-for="Promotion.IsActive"></label>
								</th>
								<td>
									<select asp-for="Promotion.IsActive" class="form-select">
										<option value="true">Active</option>
										<option value="false">Inactive</option>
									</select>
									<span asp-validation-for="Promotion.IsActive" class="text-danger"></span>
								</td>
							</tr>
							<tr>
								<th class="bg-light">
									<label asp-for="Promotion.CreatedAt"></label>
								</th>
								<td>
									<input asp-for="Promotion.CreatedAt" class="form-control" readonly />
									<span asp-validation-for="Promotion.CreatedAt" class="text-danger"></span>
								</td>
							</tr>
						</tbody>
					</table>

					<div class="mt-4">
						<div class="d-flex gap-2">
							<button type="submit" class="btn btn-primary">
								<i class="bi bi-save me-1"></i> Save Changes
							</button>
							<a asp-page="./Index" class="btn btn-outline-secondary">
								<i class="bi bi-arrow-left me-1"></i> Back to List
							</a>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}