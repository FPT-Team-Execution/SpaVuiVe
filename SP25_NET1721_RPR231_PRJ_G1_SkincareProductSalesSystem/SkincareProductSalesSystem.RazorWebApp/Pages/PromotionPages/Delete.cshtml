@page
@model SkincareProductSalesSystem.RazorWebApp.Pages.PromotionPages.DeleteModel
@{
	ViewData["Title"] = "Delete Promotion";
}

<div class="container mt-4">
	<div class="card shadow-sm border-danger">
		<div class="card-header bg-danger text-white">
			<h2 class="card-title h5 m-0">Delete Promotion</h2>
		</div>
		<div class="card-body">
			<div class="alert alert-warning" role="alert">
				<i class="bi bi-exclamation-triangle-fill me-2"></i>
				Are you sure you want to delete this promotion?
			</div>

			<div class="table-responsive">
				<table class="table table-bordered">
					<tbody>
						<tr>
							<th class="bg-light w-25">@Html.DisplayNameFor(model => model.Promotion.Code)</th>
							<td>@Html.DisplayFor(model => model.Promotion.Code)</td>
						</tr>
						<tr>
							<th class="bg-light">@Html.DisplayNameFor(model => model.Promotion.Name)</th>
							<td>@Html.DisplayFor(model => model.Promotion.Name)</td>
						</tr>
						<tr>
							<th class="bg-light">@Html.DisplayNameFor(model => model.Promotion.DiscountAmount)</th>
							<td>$@Html.DisplayFor(model => model.Promotion.DiscountAmount)</td>
						</tr>
						<tr>
							<th class="bg-light">@Html.DisplayNameFor(model => model.Promotion.MinimumPurchase)</th>
							<td>$@Html.DisplayFor(model => model.Promotion.MinimumPurchase)</td>
						</tr>
						<tr>
							<th class="bg-light">@Html.DisplayNameFor(model => model.Promotion.StartDate)</th>
							<td>@Html.DisplayFor(model => model.Promotion.StartDate)</td>
						</tr>
						<tr>
							<th class="bg-light">@Html.DisplayNameFor(model => model.Promotion.EndDate)</th>
							<td>@Html.DisplayFor(model => model.Promotion.EndDate)</td>
						</tr>
						<tr>
							<th class="bg-light">@Html.DisplayNameFor(model => model.Promotion.UsageLimit)</th>
							<td>@Html.DisplayFor(model => model.Promotion.UsageLimit)</td>
						</tr>
						<tr>
							<th class="bg-light">@Html.DisplayNameFor(model => model.Promotion.IsActive)</th>
							<td>
								<span class="badge @((bool)Model.Promotion.IsActive ? "bg-success" : "bg-danger")">
									@((bool)Model.Promotion.IsActive ? "Active" : "Inactive")
								</span>
							</td>
						</tr>
						<tr>
							<th class="bg-light">@Html.DisplayNameFor(model => model.Promotion.CreatedAt)</th>
							<td>@Html.DisplayFor(model => model.Promotion.CreatedAt)</td>
						</tr>
					</tbody>
				</table>
			</div>

			<form method="post" class="mt-4">
				<input type="hidden" asp-for="Promotion.PromotionId" />
				<div class="d-flex gap-2">
					<button type="submit" class="btn btn-danger">
						<i class="bi bi-trash-fill me-1"></i> Delete
					</button>
					<a asp-page="./Index" class="btn btn-outline-secondary">
						<i class="bi bi-arrow-left me-1"></i> Back to List
					</a>
				</div>
			</form>
		</div>
	</div>
</div>