@page
@model SkincareProductSalesSystem.RazorWebApp.Pages.PromotionPages.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Promotion[0].Code)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Promotion[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Promotion[0].DiscountAmount)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Promotion[0].MinimumPurchase)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Promotion[0].StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Promotion[0].EndDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Promotion[0].UsageLimit)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Promotion[0].IsActive)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Promotion[0].CreatedAt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Promotion) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Code)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DiscountAmount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MinimumPurchase)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StartDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UsageLimit)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsActive)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.PromotionId">Edit</a> |
                <a asp-page="./Delete" asp-route-id="@item.PromotionId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
