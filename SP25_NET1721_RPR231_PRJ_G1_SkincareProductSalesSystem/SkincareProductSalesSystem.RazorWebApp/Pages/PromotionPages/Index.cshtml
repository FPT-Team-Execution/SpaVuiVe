@page
@model SkincareProductSalesSystem.RazorWebApp.Pages.PromotionPages.IndexModel
@{
	ViewData["Title"] = "Promotions";
}

<div class="container mt-4">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1>Promotions</h1>
		<a asp-page="Create" class="btn btn-primary">Create New</a>
	</div>

	<div class="table-responsive">
		<table class="table table-striped table-hover">
			<thead class="table-dark">
				<tr>
					<th>@Html.DisplayNameFor(model => model.Promotion[0].Code)</th>
					<th>@Html.DisplayNameFor(model => model.Promotion[0].Name)</th>
					<th>@Html.DisplayNameFor(model => model.Promotion[0].DiscountAmount)</th>
					<th>@Html.DisplayNameFor(model => model.Promotion[0].MinimumPurchase)</th>
					<th>@Html.DisplayNameFor(model => model.Promotion[0].StartDate)</th>
					<th>@Html.DisplayNameFor(model => model.Promotion[0].EndDate)</th>
					<th>@Html.DisplayNameFor(model => model.Promotion[0].UsageLimit)</th>
					<th>@Html.DisplayNameFor(model => model.Promotion[0].IsActive)</th>
					<th>@Html.DisplayNameFor(model => model.Promotion[0].CreatedAt)</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var item in Model.Promotion)
				{
					<tr>
						<td>@Html.DisplayFor(modelItem => item.Code)</td>
						<td>@Html.DisplayFor(modelItem => item.Name)</td>
						<td>@Html.DisplayFor(modelItem => item.DiscountAmount)</td>
						<td>@Html.DisplayFor(modelItem => item.MinimumPurchase)</td>
						<td>@Html.DisplayFor(modelItem => item.StartDate)</td>
						<td>@Html.DisplayFor(modelItem => item.EndDate)</td>
						<td>@Html.DisplayFor(modelItem => item.UsageLimit)</td>
						<td>
							<span class="badge @((bool) item.IsActive ? "bg-success" : "bg-danger")">
								@((bool)item.IsActive ? "Active" : "Inactive")
							</span>
						</td>
						<td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
						<td>
							<div class="btn-group" role="group">
								<a asp-page="./Edit" asp-route-id="@item.PromotionId"
								   class="btn btn-sm btn-outline-primary">Edit</a>
								<a asp-page="./Delete" asp-route-id="@item.PromotionId"
								   class="btn btn-sm btn-outline-danger">Delete</a>
							</div>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
</div>